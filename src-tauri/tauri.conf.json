{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MCP Assistant",
  "version": "0.1.0",
  "identifier": "com.mcpassistant.app",
  "build": {
    "frontendDist": "../client/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev --prefix client",
    "beforeBuildCommand": "npm run build --prefix client"
  },
  "app": {
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist/agent-backend/_internal/": "agent-backend/_internal/",
      "../dist/agent-backend/agent-backend.exe": "agent-backend/agent-backend.exe",
      "../dist/agent-backend/mcp_servers.json": "agent-backend/mcp_servers.json",
      "../dist/mcp-server/": "mcp-server/"
    }
  }
}
